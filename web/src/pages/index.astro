    </div>
    <p class="text-xs text-neutral-400 mt-3">
      v{version} · macOS 10.15+ · Windows 10/11 · Linux (x64)
    </p>

    <!-- Hero Screenshot -->
    <div class="mt-12 w-full max-w-4xl">
      <img
        src="/screens/02-cluster-overview.webp"
        alt="Kubeli Cluster Overview"
        class="w-full"
      />
