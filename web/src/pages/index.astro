---

<BaseLayout title="Home" activeNav="home" canonicalPath="/" extraSchema={[faqSchema]}>
  <!-- Hero Section -->
  <section class="mx-auto flex max-w-6xl flex-col items-center px-4 sm:px-8 py-12 sm:py-20">
    <!-- Badges -->
